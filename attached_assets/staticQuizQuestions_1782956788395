  "cb-01": [
    { question: "CPU ka kaam kya hota hai computer mein?", options: ["Data store karna permanently", "Sab calculations aur instructions execute karna", "Internet se connect karna", "Screen pe display karna"], correctIndex: 1, explanation: "CPU (Central Processing Unit) computer ka brain hai — yeh sab instructions fetch, decode aur execute karta hai. Storage RAM/HDD ka kaam hai, display GPU ka." },
