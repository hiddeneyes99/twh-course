  "cb-05": [
    { question: "Decimal 255 ka hexadecimal value kya hai?", options: ["0xFF", "0xFE", "0x100", "0xAA"], correctIndex: 0, explanation: "255 = 15×16 + 15 = 0xFF. Hackers ke liye yeh critical hai — IP address bytes 0-255 hote hain, memory addresses hex mein hote hain, shellcode mein NOP = 0x90, null byte = 0x00." },
